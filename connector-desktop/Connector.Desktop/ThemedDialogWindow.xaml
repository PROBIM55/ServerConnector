<Window x:Class="Connector.Desktop.ThemedDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="620"
        WindowStartupLocation="CenterOwner"
        Title="Уведомление">
    <Border Background="#111823"
            BorderBrush="#2A3A4F"
            BorderThickness="1"
            CornerRadius="14"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0D141E" CornerRadius="14,14,0,0" Padding="14,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleTextBlock" Foreground="#E7EEF7" FontSize="14" FontWeight="SemiBold" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Width="26"
                            Height="24"
                            Background="Transparent"
                            BorderBrush="#2A3A4F"
                            BorderThickness="1"
                            Foreground="#9DB1CC"
                            FontSize="11"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="16,16,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="IconTextBlock"
                           FontSize="28"
                           Margin="0,0,10,0"
                           VerticalAlignment="Top"
                           Foreground="#8BC3FF"
                           Text="ℹ" />
                <TextBlock x:Name="MessageTextBlock"
                           Grid.Column="1"
                           TextWrapping="Wrap"
                           Foreground="#E7EEF7"
                           FontSize="14"
                           MaxWidth="520" />
            </Grid>

            <WrapPanel Grid.Row="2" Margin="16,4,16,14" HorizontalAlignment="Right">
                <Button x:Name="NoButton"
                        Content="Нет"
                        Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Background="#151F2C"
                        BorderBrush="#2A3A4F"
                        Foreground="#E7EEF7"
                        Click="NoButton_Click" />
                <Button x:Name="YesButton"
                        Content="Да"
                        Width="96"
                        Height="34"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Background="#173B38"
                        BorderBrush="#2E7168"
                        Foreground="#E7EEF7"
                        Click="YesButton_Click" />
                <Button x:Name="OkButton"
                        Content="OK"
                        Width="96"
                        Height="34"
                        Background="#173B38"
                        BorderBrush="#2E7168"
                        Foreground="#E7EEF7"
                        Click="OkButton_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
