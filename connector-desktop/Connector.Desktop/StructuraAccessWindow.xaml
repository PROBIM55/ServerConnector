<Window x:Class="Connector.Desktop.StructuraAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Доступы Structura"
        Width="580"
        Height="410"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#070B12">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#101823" />
        <SolidColorBrush x:Key="PanelBorder" Color="#2A3E5C" />
        <SolidColorBrush x:Key="InputBg" Color="#0B121B" />
        <SolidColorBrush x:Key="InputBorder" Color="#2B3C54" />
        <SolidColorBrush x:Key="CaptionBrush" Color="#9CB2CF" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F8FF" />
        <SolidColorBrush x:Key="HintBrush" Color="#87A2C5" />

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="CopyIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#142233" />
            <Setter Property="BorderBrush" Value="#335071" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Скопировать" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#5A82B1" />
                                <Setter TargetName="Root" Property="Background" Value="#182A40" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Border Background="#0E151F"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock x:Name="TitleTextBlock"
                               Text="Доступы"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="23"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Display" />
                    <TextBlock Text="Скопируйте нужные данные для входа"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource HintBrush}"
                               FontFamily="Segoe UI Variable Text" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Домен" Foreground="{StaticResource CaptionBrush}" FontFamily="Segoe UI Variable Text" FontWeight="SemiBold" />
                        <TextBox x:Name="DomainTextBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldTextBoxStyle}" IsReadOnly="True" Margin="0,0,8,8" />
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource CopyIconButtonStyle}" Click="CopyDomain_Click" Margin="0,0,0,8">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Foreground="#C8E4FF" FontSize="16" Text="&#xE8C8;" />
                        </Button>

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Логин" Foreground="{StaticResource CaptionBrush}" FontFamily="Segoe UI Variable Text" FontWeight="SemiBold" />
                        <TextBox x:Name="LoginTextBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldTextBoxStyle}" IsReadOnly="True" Margin="0,0,8,8" />
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource CopyIconButtonStyle}" Click="CopyLogin_Click" Margin="0,0,0,8">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Foreground="#C8E4FF" FontSize="16" Text="&#xE8C8;" />
                        </Button>

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Пароль" Foreground="{StaticResource CaptionBrush}" FontFamily="Segoe UI Variable Text" FontWeight="SemiBold" />
                        <TextBox x:Name="PasswordTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldTextBoxStyle}" IsReadOnly="True" Margin="0,0,8,0" />
                        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource CopyIconButtonStyle}" Click="CopyPassword_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Foreground="#C8E4FF" FontSize="16" Text="&#xE8C8;" />
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Если логин или пароль пустые, доступы еще не назначены в админской панели"
                               Foreground="{StaticResource HintBrush}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               FontFamily="Segoe UI Variable Text" />
                    <TextBlock x:Name="CopyStatusTextBlock"
                               Margin="0,8,0,0"
                               Foreground="#9FDAB5"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               Text="" />
                </StackPanel>

                <Button Grid.Row="3"
                        Content="Закрыть"
                        Width="120"
                        Height="38"
                        HorizontalAlignment="Right"
                        Background="#162334"
                        BorderBrush="#335071"
                        Foreground="#EAF2FF"
                        FontFamily="Segoe UI Variable Text"
                        Click="Close_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
