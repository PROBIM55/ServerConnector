<Window x:Class="Connector.Desktop.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Что нового"
        Width="920"
        Height="640"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#090E15">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#101823" />
        <SolidColorBrush x:Key="PanelBorder" Color="#2A3E5C" />
        <SolidColorBrush x:Key="MutedText" Color="#94AACC" />
        <SolidColorBrush x:Key="MainText" Color="#EDF4FF" />
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Column="0"
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">
            <StackPanel>
                <TextBlock Text="Релизы"
                           Foreground="{StaticResource MainText}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
                <ListBox x:Name="VersionsListBox"
                         SelectionChanged="VersionsListBox_SelectionChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource MainText}"
                         FontFamily="Segoe UI Variable Text"
                         FontSize="14"
                         DisplayMemberPath="Version" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Grid.Row="0"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="VersionHeaderTextBlock"
                           Text="Версия"
                           Foreground="{StaticResource MainText}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI Variable Display" />
                <TextBlock x:Name="VersionMetaTextBlock"
                           Grid.Row="1"
                           Margin="0,6,0,14"
                           Text="Дата релиза"
                           Foreground="{StaticResource MutedText}"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="13" />

                <ScrollViewer x:Name="ChangesScrollViewer"
                              Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Width="{Binding ElementName=ChangesScrollViewer, Path=ViewportWidth}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="VersionTitleTextBlock"
                                   Grid.Row="0"
                                   Foreground="{StaticResource MainText}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <ItemsControl x:Name="ChangesItemsControl" Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="•"
                                                   Foreground="#8EC8FF"
                                                   FontSize="16"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding}"
                                                   Foreground="{StaticResource MainText}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Segoe UI Variable Text" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Column="2"
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Закрыть"
                    Width="120"
                    Height="38"
                    Click="Close_Click"
                    Background="#162334"
                    BorderBrush="#375272"
                    Foreground="#EEF4FF"
                    FontFamily="Segoe UI Variable Text" />
        </StackPanel>
    </Grid>
</Window>
